# SparkCreatives — environment variables
# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.

# Public site URL (used for canonical URLs, sitemap, OpenGraph)
NEXT_PUBLIC_SITE_URL="https://sparkcreativesinc.org"

# --- Stripe (donations) ---
# Use TEST keys (sk_test_..., whsec_...) until ready to go live.
# The donate flow shows a friendly "not connected" state until STRIPE_SECRET_KEY is set.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Local webhook testing: `stripe listen --forward-to localhost:3000/api/stripe/webhook`

# --- Resend (transactional email: contact + donation receipts) ---
# Without a key, emails are logged to the server console instead of sent (dev-friendly).
RESEND_API_KEY=""
# Verified sender (must be a domain/address verified in Resend). Default uses Resend's sandbox.
# Production: "SparkCreatives <ignite@sparkcreativesinc.org>" (domain verified in Resend).
RESEND_FROM="SparkCreatives <onboarding@resend.dev>"
# Where contact-form submissions are delivered (main public contact alias).
CONTACT_INBOX="ignite@sparkcreativesinc.org"

# --- Supabase (reserved for Phase 2: CMS/content + form storage) ---
# NEXT_PUBLIC_SUPABASE_URL=""
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""
